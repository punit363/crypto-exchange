datasource db {
  provider = "postgresql"
}

generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"   // ← needed for tsx compatibility
}

model User {
  user_id    String   @id
  first_name String
  last_name  String
  age        Int      
  email      String   @unique
  phone      String   @unique
  password   String
  balance      Decimal  @default(0.00)
  balance_lock Decimal  @default(0.00)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  holdings     Holding[] 
  @@map("users")
}

model Asset {
  symbol        String    @id 
  name          String   
  current_price Decimal   @default(0.00)
  is_active     Boolean   @default(true)
  holdings      Holding[] 
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@map("assets")
}

model Holding {
  holding_id   String    @id @default(uuid())
  user_id      String    
  user         User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  asset_symbol String    
  asset_data   Asset     @relation(fields: [asset_symbol], references: [symbol])
  asset_balance      Decimal   @default(0.00)
  asset_balance_lock Decimal   @default(0.00)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  @@unique([user_id, asset_symbol]) 
  @@map("holdings")
}